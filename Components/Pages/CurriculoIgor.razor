@page "/Curriculo-Igor"

<section class="secao-curriculo">

    <div class="container-curriculo">

        <div class="cabecalho-curriculo">
            <span class="tag-curriculo">CURRÍCULO</span>

            <h1 class="nome-curriculo">
                Igor Gabriel
            </h1>

            <p class="objetivo-curriculo">
                Tenho interesse na área de medicina e pretendo seguir carreira como médico,
                conciliando meus conhecimentos em tecnologia para desenvolver soluções inovadoras na área da saúde.
            </p>
        </div>

        <div class="grid-curriculo">

            <div class="cartao-curriculo">

                <h2>Resumo Profissional</h2>

                <p>
                    Estudante do curso técnico em informática, com interesse na área de medicina.
                    Possuo base em desenvolvimento de sistemas e banco de dados, além de perfil
                    analítico, organização e facilidade para aprender. Busco futuramente atuar na área médica,
                    utilizando também a tecnologia como aliada na saúde.
                </p>

            </div>

            <div class="cartao-curriculo">

                <h2>Competências</h2>

                <ul>
                    <li>Desenvolvimento Web (HTML, CSS, JavaScript)</li>
                    <li>Banco de Dados (SQL e modelagem relacional)</li>
                    <li>Lógica de programação</li>
                    <li>Organização e resolução de problemas</li>
                    <li>Facilidade de aprendizado</li>
                    <li>Interesse em tecnologia aplicada à saúde</li>
                </ul>

            </div>

            <div class="cartao-curriculo cartao-destaque">

                <h2>Projetos</h2>

                <div class="projeto">
                    <h3>Sistema de Banco de Dados – Cinema 2.0</h3>

                    <ul>
                        <li>Modelagem e implementação de banco de dados completo</li>
                        <li>Criação de tabelas com chaves primárias e estrangeiras</li>
                        <li>Inserção e validação de dados com integridade referencial</li>
                    </ul>
                </div>

                <div class="projeto">
                    <h3>Sistema de Matrícula de Alunos</h3>

                    <ul>
                        <li>Desenvolvimento baseado em diagrama ER</li>
                        <li>Estruturação de tabelas e relacionamentos</li>
                        <li>Aplicação de melhorias no banco de dados</li>
                    </ul>
                </div>

                <div class="projeto">
                    <h3>Calculadora Web</h3>

                    <ul>
                        <li>Desenvolvimento com HTML, CSS e JavaScript</li>
                        <li>Implementação de funcionalidades com armazenamento local</li>
                        <li>Validação de dados e interação com o usuário</li>
                    </ul>
                </div>

            </div>

            <div class="cartao-curriculo">

                <h2>Formação Acadêmica</h2>

                <p>
                    <strong>Curso:</strong> Técnico em Informática
                </p>

                <p>
                    <strong>Instituição:</strong> IFRO
                </p>

                <p>
                    <strong>Status:</strong> Em andamento
                </p>

            </div>

            <div class="cartao-curriculo">

                <h2>Resultados e Diferenciais</h2>

                <ul>
                    <li>Capacidade de unir tecnologia com outras áreas de interesse</li>
                    <li>Desenvolvimento de projetos práticos</li>
                    <li>Pensamento lógico e analítico</li>
                    <li>Comprometimento com aprendizado contínuo</li>
                </ul>

            </div>

            <div class="cartao-curriculo">

                <h2>Informações Adicionais</h2>

                <ul>
                    <li>Interesse em medicina</li>
                    <li>Objetivo de seguir carreira como médico</li>
                    <li>Curso técnico em informática em andamento</li>
                    <li>Interesse em tecnologia aplicada à área da saúde</li>
                </ul>

            </div>

        </div>

    </div>

</section>

<style>

    .secao-curriculo {
        background: #f1f5f9;
        min-height: 100vh;
        padding: 4rem 1.5rem;
    }

    .container-curriculo {
        max-width: 1200px;
        margin: 0 auto;
    }

    .cabecalho-curriculo {
        text-align: center;
        margin-bottom: 3rem;
    }

    .tag-curriculo {
        display: inline-block;
        background: #ffe5ec;
        color: #ff006e;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        padding: 0.5rem 0.9rem;
        border-radius: 999px;
        margin-bottom: 1rem;
    }

    .nome-curriculo {
        font-family: "Georgia", "Times New Roman", serif;
        font-size: clamp(2.5rem, 5vw, 4rem);
        color: #8338ec;
        margin-bottom: 1rem;
    }

    .objetivo-curriculo {
        max-width: 700px;
        margin: 0 auto;
        color: #475569;
        font-size: 1.1rem;
        line-height: 1.8;
    }

    .grid-curriculo {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.5rem;
    }

    .cartao-curriculo {
        background: #ffffff;
        border-radius: 20px;
        padding: 2rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    }

    .cartao-destaque {
        grid-column: span 2;
    }

    .cartao-curriculo h2 {
        color: #ff006e;
        font-size: 1.4rem;
        margin-bottom: 1rem;
    }

    .cartao-curriculo h3 {
        color: #8338ec;
        margin-bottom: 0.8rem;
        margin-top: 1.5rem;
    }

    .cartao-curriculo p,
    .cartao-curriculo li {
        color: #334155;
        line-height: 1.8;
    }

    .cartao-curriculo ul {
        padding-left: 1.2rem;
        margin: 0;
    }

    .projeto:first-child h3 {
        margin-top: 0;
    }

    @@media (max-width: 900px) {

        .grid-curriculo {
            grid-template-columns: 1fr;
        }

        .cartao-destaque {
            grid-column: span 1;
        }
    }

    @@media (max-width: 640px) {

        .secao-curriculo {
            padding: 2rem 1rem;
        }

        .cartao-curriculo {
            padding: 1.5rem;
            border-radius: 16px;
        }

        .nome-curriculo {
            font-size: 2.5rem;
        }
    }

</style>